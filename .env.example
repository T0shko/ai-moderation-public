# Database configuration used by Docker-compose and Spring Boot
POSTGRES_DB=aimoderation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_database_password
DB_PASSWORD=your_database_password

# JWT Token Configuration
JWT_SECRET=your_jwt_secret_change_this_to_a_secure_value_at_least_64_characters_long

# AI Provider Keys (Optional: Leave blank if using local models or not enabled)
HUGGINGFACE_API_TOKEN=