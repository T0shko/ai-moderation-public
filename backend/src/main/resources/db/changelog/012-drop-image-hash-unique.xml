<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

  <!-- Allow multiple scan rows per image hash (each Vision Lab upload is a new row). -->
  <changeSet id="012-drop-image-hash-unique" author="system">
    <dropUniqueConstraint
        tableName="image_moderation_result"
        constraintName="image_moderation_result_image_hash_key"/>
  </changeSet>

</databaseChangeLog>
