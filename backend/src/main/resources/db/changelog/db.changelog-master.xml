<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="001-create-users-table" author="system">
        <createTable tableName="users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Create index on username for faster lookups -->
        <createIndex indexName="idx_users_username" tableName="users">
            <column name="username"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-comments-table" author="system">
        <createTable tableName="comment">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="content" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="sentiment" type="varchar(20)">
                <constraints nullable="true"/>
            </column>
            <column name="confidence_score" type="double precision">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- Create foreign key constraint -->
        <addForeignKeyConstraint
            baseTableName="comment"
            baseColumnNames="user_id"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_comment_user_id"/>

        <!-- Create indexes for better performance -->
        <createIndex indexName="idx_comment_user_id" tableName="comment">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_comment_status" tableName="comment">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_comment_created_at" tableName="comment">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-insert-default-admin-user" author="system">
        <insert tableName="users">
            <column name="username" value="admin"/>
            <!-- Password is 'admin123' encoded with BCrypt -->
            <column name="password" value="$2a$10$r.mMnajPrNvJMAcO6hfFaOsZHIccFH/16Pk5Ywg3FXAkYSgQDtbGK"/>
            <column name="role" value="ADMIN"/>
        </insert>
    </changeSet>

    <include file="db/changelog/004-create-ai-settings-table.xml"/>
    <include file="db/changelog/005-create-training-data-table.xml"/>
    <include file="db/changelog/006-create-image-moderation-table.xml"/>
</databaseChangeLog>
