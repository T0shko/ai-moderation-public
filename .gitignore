# ============================================================
# AI Moderation App — .gitignore
# Keep ONLY: backend Java source, frontend Dart/lib source,
#            pom.xml, pubspec.yaml/lock, docker-compose, start.sh
# ============================================================

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ── IDE / Editor ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ── AI Agents / Settings ─────────────────────────────────────
.claude/
.agents/
.antigravity/

# ── Secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example
application-local.properties

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────────────────────────
# JAVA / MAVEN
# ─────────────────────────────────────────────────────────────
backend/target/
backend/.gitignore
backend/src/test/
*.class
*.jar
*.war

# ─────────────────────────────────────────────────────────────
# FLUTTER — generated / tooling
# ─────────────────────────────────────────────────────────────
frontend/.dart_tool/
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/coverage/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.metadata
frontend/.gitignore
frontend/README.md
frontend/analysis_options.yaml
frontend/test/

# ── Platform runner code (boilerplate, not our code) ─────────
frontend/android/
frontend/ios/
frontend/macos/
frontend/linux/
frontend/windows/
frontend/web/
